# Copia este fichero a infra/.env y rellénalo con TU tenant (nunca commitees .env)

# --- Identidad del tenant (M01-01, obligatorio) ---
# URL base SIN barra final y SIN /ui/...
# Recomendado (API/scripts del curso): https://<id>.live.dynatrace.com
# El <id> debe ser el mismo que ves en el navegador (.live o .apps).
DYNATRACE_ENVIRONMENT_URL=

# Prefijo de la URL (mismo valor en ambos formatos). Ejemplo: abc12345
DYNATRACE_ENVIRONMENT_ID=

# --- Tokens (generar en M01-01; usar en M03/M05) ---
# Ver labs/M01-entorno-codespace-plataforma/M01-01-bootstrap-entorno.md pasos 2c–2e

# M03 — OneAgent en Docker (tipo PaaS en Access tokens)
ONEAGENT_PAAS_TOKEN=

# M05 — Dynatrace Operator (API platform; scopes ReadConfig + WriteConfig mínimo)
DYNATRACE_API_TOKEN=

# M04/M05 — Ingest Grail (scopes metrics.ingest, logs.ingest, openTelemetryTrace.ingest)
# M04: demo-api envía trazas OTLP al tenant con este token (Codespace)
DYNATRACE_INGEST_TOKEN=

# Reservado / no usado por scripts actuales del curso (puedes dejarlo vacío)
DYNATRACE_OPERATOR_TOKEN=

# Opcional: URL explícita del instalador OneAgent Linux x86.
# Si vacío, scripts/oneagent-up.sh la deriva de DYNATRACE_ENVIRONMENT_URL
ONEAGENT_INSTALLER_SCRIPT_URL=

# Opcional: false en Codespace/DinD si oneagent-up.sh no detecta el entorno.
# ONEAGENT_ENABLE_VOLUME_STORAGE=false
